{
  "name": "school-lost-found",
  "version": "1.0.0",
  "description": "Green Level Lost & Found Website - FBLA 2026",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon --ignore data/ server/index.js",
    "build:css": "tailwindcss -c tailwind.config.cjs -i ./public/css/tailwind-source.css -o ./public/css/tailwind-local.css --minify",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:check": "node scripts/verify-local-postgres.js",
    "db:prepare": "npm run prisma:validate && npm run prisma:generate && npm run prisma:deploy && npm run data:migrate-json",
    "db:reset:local": "prisma migrate reset --force && npm run data:migrate-json",
    "data:migrate-json": "node scripts/migrate-json-to-postgres.js",
    "map:cad": "node scripts/generate-campus-cad-workspace.js",
    "map:cad:clean": "node scripts/convert-clean-dxf-to-map.js",
    "email:check": "node scripts/check-email-config.js",
    "test": "node tests/run.js",
    "test:ui": "npx playwright test"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "connect-pg-simple": "^10.0.0",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.17.3",
    "gsap": "^3.15.0",
    "heic-convert": "^2.1.0",
    "helmet": "^8.2.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.11",
    "openai": "^6.44.0",
    "pg": "^8.21.0",
    "three": "^0.184.0",
    "uuid": "^11.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "nodemon": "^3.0.2",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.17"
  }
}
