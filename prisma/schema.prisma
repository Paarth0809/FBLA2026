// Green Level Lost & Found production-lite schema. Prisma keeps the PostgreSQL
// database typed, migrated, and consistent across local demos and Vercel/Neon.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Roles stay intentionally small so route guards can make clear admin/student decisions.
enum Role {
  USER
  ADMIN
}

// Found items are hidden until review and move through a controlled admin workflow.
enum FoundItemStatus {
  PENDING
  APPROVED
  REJECTED
  CLAIMED
}

// Missing-item reports follow the same moderation path, then close when recovered.
enum MissingItemStatus {
  PENDING
  APPROVED
  REJECTED
  FOUND
}

// Claim status is separate from item status so approvals can be transactional.
enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

// Shared item type lets claims and messages point to found or missing workflows.
enum ItemType {
  FOUND
  MISSING
}

// Upload purposes document why each stored file exists and who should see it.
enum AssetPurpose {
  FOUND_ITEM_PHOTO
  MISSING_ITEM_PHOTO
  CLAIM_EVIDENCE
}

// Audit actions are explicit so admin/user activity remains explainable to judges.
enum AuditAction {
  DATA_MIGRATED
  USER_SIGNED_UP
  USER_LOGGED_IN
  FOUND_ITEM_CREATED
  MISSING_ITEM_CREATED
  FOUND_ITEM_APPROVED
  FOUND_ITEM_REJECTED
  FOUND_ITEM_DELETED
  FOUND_ITEM_MARKED_CLAIMED
  MISSING_ITEM_APPROVED
  MISSING_ITEM_REJECTED
  MISSING_ITEM_DELETED
  MISSING_ITEM_MARKED_FOUND
  CLAIM_CREATED
  CLAIM_APPROVED
  CLAIM_REJECTED
  CLAIM_DELETED
  MESSAGE_SENT
  MESSAGE_DELETED
  ACCOUNT_DELETED
}

// Users own submissions, claims, messages, preferences, and audit records.
model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  foundItems    FoundItem[]
  missingItems  MissingItem[]
  claims        Claim[]       @relation("ClaimSubmitter")
  ownedClaims   Claim[]       @relation("ClaimOwner")
  sentMessages  Message[]     @relation("MessageSender")
  inboxMessages Message[]     @relation("MessageReceiver")
  uploadedAssets UploadedAsset[]
  auditLogs     AuditLog[]    @relation("AuditActor")
  settings      UserSettings?
  notificationPreference NotificationPreference?
  notificationLogs NotificationLog[]
}

// Found items store private contact email separately from the public item shape.
model FoundItem {
  id                  String           @id @default(uuid())
  itemName            String
  category            String
  description         String
  locationFound       String
  dateFound           DateTime
  contactEmailPrivate String
  status              FoundItemStatus  @default(PENDING)
  submitterName       String
  mapFloorId          String?
  mapRoomId           String?
  mapRoomNumber       String?
  mapPinX             Float?
  mapPinZ             Float?
  aiProfile           Json?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  submittedById String
  submittedBy   User   @relation(fields: [submittedById], references: [id], onDelete: Cascade)

  photoAssetId String?
  photoAsset   UploadedAsset? @relation("FoundItemPhoto", fields: [photoAssetId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([submittedById])
  @@index([status, mapFloorId, mapRoomId])
  @@index([mapRoomId])
}

// Missing items mirror found-item privacy and moderation without map pin fields yet.
model MissingItem {
  id                  String            @id @default(uuid())
  itemName            String
  category            String
  description         String
  lastSeenLocation    String
  lastSeenDate        DateTime
  contactEmailPrivate String
  status              MissingItemStatus @default(PENDING)
  submitterName       String
  aiProfile           Json?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  submittedById String
  submittedBy   User   @relation(fields: [submittedById], references: [id], onDelete: Cascade)

  photoAssetId String?
  photoAsset   UploadedAsset? @relation("MissingItemPhoto", fields: [photoAssetId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([submittedById])
}

// Claims capture proof-of-ownership requests and the owner/admin decision lifecycle.
model Claim {
  id               String      @id @default(uuid())
  itemId           String
  itemType         ItemType
  itemName         String
  claimerName      String
  claimerEmail     String
  claimerPhone     String?
  description      String
  status           ClaimStatus @default(PENDING)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  submittedById String
  submittedBy   User   @relation("ClaimSubmitter", fields: [submittedById], references: [id], onDelete: Cascade)

  ownerId String?
  owner   User?   @relation("ClaimOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([itemType, itemId])
  @@index([submittedById])
  @@index([ownerId])
}

// Messages are user-id based, not email based, so permissions remain enforceable.
model Message {
  id          String   @id @default(uuid())
  itemId      String
  itemType    ItemType?
  itemName    String
  content     String
  replyToId   String?
  createdAt   DateTime @default(now())

  senderId   String
  sender     User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([senderId])
  @@index([receiverId])
}

// Uploaded assets keep file metadata/provenance separate from item records.
model UploadedAsset {
  id           String       @id @default(uuid())
  ownerId      String
  owner        User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  originalName String
  storedName   String       @unique
  mimeType     String
  contentType  String?
  sizeBytes    Int
  sha256       String?
  purpose      AssetPurpose
  storageProvider String    @default("local")
  storageKey      String?
  publicUrl       String?
  createdAt    DateTime     @default(now())

  foundItemPhoto   FoundItem[]   @relation("FoundItemPhoto")
  missingItemPhoto MissingItem[] @relation("MissingItemPhoto")

  @@index([ownerId])
  @@index([storageProvider, storageKey])
}

// User settings hold account-synced accessibility and language preferences.
model UserSettings {
  id                   String   @id @default(uuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferredLanguage    String   @default("en")
  dyslexicFontEnabled  Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// Notification preferences let users control which email alerts are sent.
model NotificationPreference {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email         String?
  emailEnabled  Boolean  @default(true)
  matchAlerts   Boolean  @default(true)
  claimAlerts   Boolean  @default(true)
  statusAlerts  Boolean  @default(true)
  messageAlerts Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Notification logs make demo email behavior auditable without exposing secrets.
model NotificationLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String?
  type      String
  subject   String
  status    String
  error     String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// Audit logs record important security and workflow events across the system.
model AuditLog {
  id         String      @id @default(uuid())
  actorId    String?
  actor      User?       @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action     AuditAction
  targetType String
  targetId   String?
  metadata   Json?
  createdAt  DateTime    @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
}
