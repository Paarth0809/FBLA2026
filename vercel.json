{
  "version": 2,
  "buildCommand": "npm run vercel:build",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/uploads/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/$1" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  }
}
