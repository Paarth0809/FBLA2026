# Local server
PORT=3000
NODE_ENV=development

# Required before a hosted deployment. The app has a dev-only fallback for local
# demos, but judges and production should use a long random value.
SESSION_SECRET=replace-with-a-long-random-secret

# Demo/offline mode
# The app runs from local JSON data by default so it works with slow or no Wi-Fi.
DATA_DIR=data

# Production-lite database lane
# Use this when running Prisma migrations or a Postgres-backed deployment.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/green_level_lost_found
SESSION_STORE=memory
# Set SESSION_STORE=postgres when DATABASE_URL points to a running Postgres DB.

# Optional photo profile generation for matching. Leave disabled for judge demos
# unless you have a network connection and a configured provider key.
AI_MATCHING_ENABLED=false
GEMINI_API_KEY=
