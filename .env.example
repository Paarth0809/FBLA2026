# Local server
PORT=3000
NODE_ENV=development

# Required before a hosted deployment. The app has a dev-only fallback for local
# demos, but judges and production should use a long random value.
SESSION_SECRET=replace-with-a-long-random-secret

# Local PostgreSQL database lane
# Create these databases locally, then keep this file untracked as .env.
DATABASE_URL=postgresql://fbla_app:replace-with-local-password@localhost:5432/fbla2026_dev?schema=public
TEST_DATABASE_URL=postgresql://fbla_app:replace-with-local-password@localhost:5432/fbla2026_test?schema=public
SESSION_STORE=postgres

# Public URL used inside password-reset and notification emails.
# Vercel also provides VERCEL_URL automatically, but set this after assigning a
# final production domain.
PUBLIC_APP_URL=http://localhost:3000

# Upload storage. Local development uses ./uploads; Vercel should use Blob.
# To migrate existing local UploadedAsset rows/files after setting Blob credentials:
# npm run uploads:migrate-blob -- --dry-run
# npm run uploads:migrate-blob
UPLOAD_STORAGE=local
# UPLOAD_STORAGE=vercel-blob
# BLOB_READ_WRITE_TOKEN=

# Optional source directory for importing legacy JSON demo data with:
# npm run data:migrate-json
DATA_DIR=data

# Shared AI provider configuration. Put your real key only in local .env.
# Leave matching disabled for judge demos unless you have a network connection.
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_GATORBOT_MODEL=gpt-5.4-mini
OPENAI_AI_PROFILE_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_MS=6500
GATORBOT_AI_ENABLED=true
AI_MATCHING_ENABLED=false

# Optional real email delivery for password reset and alert notifications.
# Leave EMAIL_PROVIDER=preview for offline/local judge demos; the app will show/log
# a local reset link instead. Use EMAIL_PROVIDER=resend in production after adding
# RESEND_API_KEY and a verified sender/domain in Resend.
EMAIL_PROVIDER=preview
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=no-reply@yourdomain.com
# RESEND_FROM_NAME=Green Level Lost & Found
# EMAIL_FROM="Green Level Lost & Found <no-reply@yourdomain.com>"
#
# Legacy SMTP fallback. For Gmail, use an App Password, not your normal password.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-google-app-password
# SMTP_FROM_EMAIL=your-email@gmail.com
# SMTP_FROM_NAME=Green Level Lost & Found
#
# Optional SMTP troubleshooting knobs. Keep this true/blank unless a school
# network or local certificate issue blocks the SMTP handshake.
# SMTP_TLS_REJECT_UNAUTHORIZED=true
# SMTP_CONNECTION_TIMEOUT_MS=10000
# SMTP_GREETING_TIMEOUT_MS=10000
# SMTP_SOCKET_TIMEOUT_MS=15000
