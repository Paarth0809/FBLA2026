# AI-powered item matching (optional)
# Set AI_MATCHING_ENABLED=true and provide your Gemini API key
# to enable Gemini 2.5 Flash vision analysis of item photos.
# Free tier: 1,500 requests/day — get a key at aistudio.google.com
# If disabled, matching falls back to keyword/category comparison.
AI_MATCHING_ENABLED=false
GEMINI_API_KEY=your-gemini-api-key-here
